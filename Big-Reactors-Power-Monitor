local playSounds = true

-- Queue-based sound player
local soundQueue = {}

local reactor = peripheral.find("BigReactors-Reactor")
while reactor == nil do
    print("Reactor not found, please connect a reactor and try again.")
    reactor = peripheral.find("BigReactors-Reactor")
    sleep(1)
end

local mon = peripheral.find("monitor")
while mon == nil do
    print("Monitor not found, please connect a monitor and try again.")
    mon = peripheral.find("monitor")
    sleep(1)
end

local spkr = peripheral.find("speaker")
if spkr == nil then
    print("Speaker not found")
end

mon.clear()
mon.setBackgroundColor(colors.blue)

