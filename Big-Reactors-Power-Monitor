local function clamp(value, minValue, maxValue)
    if value < minValue then
        return minValue
    elseif value > maxValue then
        return maxValue
    end
    return value
end

local function setBGColor()
    if reactor.getActive() then
        mon.setBackgroundColor(colors.blue)
    else
        mon.setBackgroundColor(colors.red)
    end
end

local function centerText(y, text, width)
    local x = math.max(1, math.floor((width - #text) / 2) + 1)
    mon.setCursorPos(x, y)
    mon.write(text)
end

local function drawBarLine(y, label, value, maxValue, note, width)
    local labelText = label .. " "
    mon.setCursorPos(1, y)
    mon.write(labelText)

    local text = note or ""
    local barStart = #labelText + 1
    local maxBarWidth = width - barStart - #text - 2
    if maxBarWidth < 6 then
        local line = label .. " " .. text
        mon.setCursorPos(1, y)
        mon.write(line)
        return
    end

    local fraction = 0
    if maxValue and maxValue > 0 then
        fraction = value / maxValue
    end
    local fillCount = clamp(math.floor(fraction * maxBarWidth + 0.5), 0, maxBarWidth)

    for i = 1, maxBarWidth do
        mon.setCursorPos(barStart + i - 1, y)
        if i <= fillCount then
            mon.setBackgroundColor(colors.green)
        else
            mon.setBackgroundColor(colors.white)
        end
        mon.write(" ")
    end
    setBGColor()

    if #text > 0 then
        mon.setCursorPos(barStart + maxBarWidth + 1, y)
        mon.write(text)
    end
end

local function playAlarm(beeps, pitch, delay)
    if playSounds then
        if spkr ~= nil then
            beeps = beeps or 6
            pitch = pitch or 1.5
            delay = delay or 0.3

            for i = 1, beeps do
                spkr.playSound("minecraft:block.note_block.pling", 3, pitch)
                sleep(delay)
            end
        else
            print("Speaker not found, cannot play alarm.")
        end
    end
end

term.clear()
term.setCursorPos(1, 1)
print("Starting Big Reactors Power Monitor...")
--playAlarm()

local function playReactorStart()
    if playSounds and spkr ~= nil then
        -- rising tone sequence, signals "power up"
        local pitches = {0.5, 0.75, 1.0, 1.25, 1.5}
        for _, p in ipairs(pitches) do
            spkr.playSound("minecraft:block.note_block.hat", 3, p)
            sleep(0.08)
        end
        spkr.playSound("minecraft:block.beacon.activate", 3, 1)
    end
end

local function playReactorStop()
    if playSounds and spkr ~= nil then
        -- falling tone sequence, signals "power down"
        local pitches = {1.5, 1.25, 1.0, 0.75, 0.5}
        for _, p in ipairs(pitches) do
            spkr.playSound("minecraft:block.note_block.hat", 3, p)
            sleep(0.08)
        end
        spkr.playSound("minecraft:block.beacon.deactivate", 3, 1)
    end
end

local function draw()
    setBGColor()
    mon.clear()

    power = reactor.getEnergyStored()
    maxPower = reactor.getEnergyCapacity()
    fuel = reactor.getFuelAmount()
    maxFuel = reactor.getFuelAmountMax()
    fuelConsumed = reactor.getFuelConsumedLastTick()
    rf = reactor.getEnergyProducedLastTick()
    maxRf = 10000

    local width, height = mon.getSize()
    local activeText = reactor.getActive() and "ACTIVE" or "INACTIVE"
    local title = "Reactor " .. tostring(reactor.getEnergyStoredAsText()) .. " [" .. activeText .. "]"
    centerText(1, title, width)

    local line = 3
    drawBarLine(line, "Power:", power, maxPower, math.floor(power / 1000) .. "kRF", width)
    line = line + 2
    drawBarLine(line, "Fuel:", fuel, maxFuel, math.floor((fuel / maxFuel) * 100) .. " %", width)
    line = line + 2

    if height >= 10 then
        drawBarLine(line, "RF/t:", rf, maxRf, string.format("%.2fk", rf / 1000), width)
        line = line + 2
    end

    if height >= 12 then
        mon.setCursorPos(1, line)
        mon.write("Fuel burn: " .. string.format("%.2f uB/t", fuelConsumed))
    end

    
end

local function queueSound(fn)
    table.insert(soundQueue, fn)
end

local function pushSound(fn)
    queueSound(fn)
    os.queueEvent("sound_queue_push")
end

local function soundPlayer()
    while true do
        if #soundQueue > 0 then
            local fn = table.remove(soundQueue, 1)
            fn()
        else
            os.pullEvent("sound_queue_push") -- sleep until woken
        end
    end
end

local function mainLoop()
  local lastStored, lastCapacity
  while true do
    draw()

    local capacity = reactor.getEnergyCapacity()
    local stored = reactor.getEnergyStored()
    if lastCapacity ~= capacity or lastStored ~= stored then
        print("Stored: " .. stored .. " Capacity: " .. capacity)
    end
    if stored >= (capacity * 0.8) and reactor.getActive() == true then
        print("Reactor Energy is full, shutting down.")
        reactor.setActive(false)
        pushSound(playReactorStop)
    end

    if stored <= (reactor.getEnergyCapacity() / 4) and reactor.getActive() == false then
        print("Reactor Energy is low, starting up.")
        reactor.setActive(true)
        pushSound(playReactorStart)
    end

    if fuel <= (reactor.getFuelAmountMax() / 100) then
        print("Reactor Fuel is low! sounding alarm.")
        pushSound(playAlarm)
    end
    lastStored = stored
    lastCapacity = capacity
    sleep(2)
  end
end

parallel.waitForAny(mainLoop, soundPlayer)