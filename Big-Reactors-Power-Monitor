local function playReactorStart()
    if playSounds and spkr ~= nil then
        -- rising tone sequence, signals "power up"
        local pitches = {0.5, 0.75, 1.0, 1.25, 1.5}
        for _, p in ipairs(pitches) do
            spkr.playSound("minecraft:block.note_block.hat", 3, p)
            sleep(0.08)
        end
        spkr.playSound("minecraft:block.beacon.activate", 3, 1)
    end
end

local function playReactorStop()
    if playSounds and spkr ~= nil then
        -- falling tone sequence, signals "power down"
        local pitches = {1.5, 1.25, 1.0, 0.75, 0.5}
        for _, p in ipairs(pitches) do
            spkr.playSound("minecraft:block.note_block.hat", 3, p)
            sleep(0.08)
        end
        spkr.playSound("minecraft:block.beacon.deactivate", 3, 1)
    end
end

local function formatPower(value)
    local absValue = math.abs(value)
    local units = {
        {suffix = "RF/T", factor = 1},
        {suffix = "kRF/T", factor = 1e3},
        {suffix = "mRF/T", factor = 1e6},
        {suffix = "gRF/T", factor = 1e9},
        {suffix = "tRF/T", factor = 1e12},
    }

    local selected = units[1]
    for i = 1, #units do
        if absValue >= units[i].factor then
            selected = units[i]
        else
            break
        end
    end

    local scaled = value / selected.factor
    local formatted = string.format("%.1f", scaled)
    if formatted:match("%.0$") then
        formatted = formatted:sub(1, -3)
    end

    return formatted, selected.suffix, scaled
end

local function draw()
    setBGColor()
    mon.clear()

    local power = reactor.getEnergyStored()
    local maxPower = reactor.getEnergyCapacity()
    fuel = reactor.getFuelAmount()
    local maxFuel = reactor.getFuelAmountMax()
    local fuelConsumed = reactor.getFuelConsumedLastTick()
    local rf = reactor.getEnergyProducedLastTick()
    if rf > maxRf then
        maxRf = rf
    end

    local valueText, unitSuffix, scaledValue = formatPower(power)

    if type(power) ~= "number" then
        power = 0
    end
    if type(maxPower) ~= "number" then
        maxPower = 0
    end
    if type(fuel) ~= "number" then
        fuel = 0
    end
    if type(maxFuel) ~= "number" then
        maxFuel = 0
    end
    if type(fuelConsumed) ~= "number" then
        fuelConsumed = 0
    end
    if type(rf) ~= "number" then
        rf = 0
    end
    if type(maxRf) ~= "number" then
        maxRf = 0
    end

    local width, height = mon.getSize()
    local activeText = reactor.getActive() and "ACTIVE" or "INACTIVE"
    local title = "Reactor " .. tostring(reactor.getEnergyStoredAsText()) .. " [" .. activeText .. "]"
    centerText(1, title, width)

    local line = 3
    drawBarLine(line, "Power:", power, maxPower, valueText .. " " .. unitSuffix, width)
    line = line + 2
    drawBarLine(line, "Fuel:", fuel, maxFuel, math.floor((fuel / maxFuel) * 100) .. " %", width)
    line = line + 2

    if height >= 10 then
        local rfText, rfSuffix, rfScaled = formatPower(rf)
        drawBarLine(line, "RF/t:", rf, maxRf, rfText .. " " .. rfSuffix, width)
        line = line + 2
    end

    if height >= 12 then
        mon.setCursorPos(1, line)
        mon.write("Fuel burn: " .. string.format("%.2f uB/t", fuelConsumed))
    end

end

local function queueSound(fn)
    table.insert(soundQueue, fn)
end

local function pushSound(fn)
    queueSound(fn)
    os.queueEvent("sound_queue_push")
end

local function soundPlayer()
    while true do
        if #soundQueue > 0 then
            local fn = table.remove(soundQueue, 1)
            fn()
        else
            os.pullEvent("sound_queue_push") -- sleep until woken
        end
    end
end

local function mainLoop()
    local lastStored, lastCapacity
    while true do
        if reactor ~= nil then
            draw()

            local capacity = reactor.getEnergyCapacity()
            local stored = reactor.getEnergyStored()
            local active = reactor.getActive()

            if type(capacity) ~= "number" then
                capacity = 0
            end
            if type(stored) ~= "number" then
                stored = 0
            end
            if type(active) ~= "boolean" then
                active = false
            end

            if lastCapacity ~= capacity or lastStored ~= stored then
                print("Stored: " .. stored .. " Capacity: " .. capacity)
            end
            if stored >= (capacity * 0.8) and active == true then
                print("Reactor Energy is full, shutting down.")
                reactor.setActive(false)
                pushSound(playReactorStop)
            end

            if stored <= (capacity / 4) and active == false then
                print("Reactor Energy is low, starting up.")
                reactor.setActive(true)
                pushSound(playReactorStart)
            end

            if fuel <= (reactor.getFuelAmountMax() / 100) then
                print("Reactor Fuel is low! sounding alarm.")
                pushSound(playAlarm)
            end
            lastStored = stored
            lastCapacity = capacity
        else
            reactor = peripheral.find("BigReactors-Reactor")
        end
        sleep(2)
    end
end

parallel.waitForAny(mainLoop, soundPlayer)
